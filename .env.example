# Copy this file to .env.local and fill your values.
# Do not commit .env.local or real keys.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com
OPENAI_SYSTEM_PROMPT=You are a concise, policy-compliant support assistant.
OPENAI_TEMPERATURE=0

EVALRAIL_PROVIDER_ID=openai
EVALRAIL_SUITE=support-quality-openai
EVALRAIL_MODE=off
EVALRAIL_STORE_DIR=.evalrail
