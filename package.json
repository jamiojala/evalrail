{
  "name": "@jamiojala/evalrail",
  "version": "0.2.0",
  "description": "Local-first prompt testing and evaluation framework for TypeScript teams.",
  "license": "MIT",
  "author": "Jami Ojala",
  "homepage": "https://github.com/jamiojala/evalrail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamiojala/evalrail.git"
  },
  "bugs": {
    "url": "https://github.com/jamiojala/evalrail/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check": "pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "example:basic": "tsx examples/basic.ts",
    "example:compare": "tsx examples/provider-compare.ts",
    "example:openai": "tsx examples/openai.ts"
  },
  "keywords": [
    "prompt-testing",
    "evaluation",
    "llm",
    "regression-testing",
    "typescript",
    "openai-compatible"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  }
}
